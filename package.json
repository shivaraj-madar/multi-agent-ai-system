{
  "name": "multi-agent-ai-system",
  "version": "1.0.0",
  "description": "Multi-Agent AI System with Memory — Day 46 Mini Project",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start:api": "node api/server.js",
    "start:classifier": "node agents/classifier.js",
    "start:router": "node agents/router.js",
    "start:executor": "node agents/executor.js",
    "start:notifier": "node notifications/notifier.js",
    "start:dashboard": "node monitoring/dashboard.js",
    "dev:api": "nodemon api/server.js",
    "dev:classifier": "nodemon agents/classifier.js",
    "dev:router": "nodemon agents/router.js",
    "dev:executor": "nodemon agents/executor.js",
    "dev:notifier": "nodemon notifications/notifier.js",
    "dev:dashboard": "nodemon monitoring/dashboard.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart",
    "docker:clean": "docker compose down -v",
    "test:webhook": "node scripts/test-webhook.js",
    "test:env": "python scripts/test_env.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.3.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
